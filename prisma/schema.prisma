datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CREATOR
  EVENTEE
}

enum TicketStatus {
  VALID
  SCANNED
  CANCELLED
  REFUNDED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

// 1. Users Table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(EVENTEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  events       Event[] // Events this user has created
  tickets      Ticket[] // Tickets this user has purchased
  transactions Transaction[]
}

// 2. Events Table
model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  date        DateTime
  capacity    Int
  price       Int      @default(0)
  createdAt   DateTime @default(now())

  // Relationships
  creatorId    String
  creator      User          @relation(fields: [creatorId], references: [id])
  tickets      Ticket[]
  transactions Transaction[] // <-- NEW: Tracks revenue attempts for this event
}

// 3. Tickets Table
model Ticket {
  id        String       @id @default(uuid())
  status    TicketStatus @default(VALID)
  createdAt DateTime     @default(now())
  isScanned Boolean      @default(false) // Track if the ticket has been scanned at the event entrance

  // Relationships
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([userId, eventId]) // Ensure a user can only purchase one ticket per event
}

// 4.Transactions Table (NEW LEDGER)
model Transaction {
  id        String            @id @default(uuid())
  reference String            @unique // The UUID sent to Paystack
  amount    Int // The price in Kobo
  status    TransactionStatus @default(PENDING)

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
